{
  "compilerOptions": {
    "skipLibCheck": true,
    "jsx": "react",
    "module": "commonjs",
    "noImplicitAny": false,
    "preserveConstEnums": true,
    "removeComments": true,
    "target": "ES6",
    "allowJs": true,
    "outDir": "public/dist",
    "sourceMap": true,
    "lib": ["es6", "dom"],
    "suppressImplicitAnyIndexErrors": true,
    "noImplicitReturns": false,
    "strict": false
  },
  "exclude": [
    "node_modules",
    "typings/browser.d.ts",
    "typings/browser",
    "tests"
  ]
}
