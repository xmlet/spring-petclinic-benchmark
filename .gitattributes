# Ensure shell scripts have LF line endings (cross-platform Docker compatibility)
* text=auto eol=lf

# Shell scripts must be executable
*.sh text eol=lf
*.groovy text eol=lf
*.jmx binary

# Maven and Gradle wrappers must be executable
mvnw text eol=lf
gradlew text eol=lf

# Keep CRLF for Windows batch files
*.cmd text eol=crlf
*.bat text eol=crlf
